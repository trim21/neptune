{
  "name": "@trim21/neptune",
  "version": "0.1.0",
  "description": "TypeScript SDK for Neptune BitTorrent client JSON-RPC API",
  "keywords": [
    "neptune",
    "bittorrent",
    "json-rpc",
    "client"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trim21/neptune.git",
    "directory": "sdk/typescript"
  },
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/client.node.js",
        "require": "./dist/client.node.js",
        "types": "./dist/client.node.d.ts"
      },
      "browser": {
        "import": "./dist/client.browser.js",
        "types": "./dist/client.browser.d.ts"
      },
      "default": {
        "import": "./dist/client.browser.js",
        "types": "./dist/client.browser.d.ts"
      }
    },
    "./src/*": "./src/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "0.22.4",
    "typescript": "6.0.3"
  }
}
